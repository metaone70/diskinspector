	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>C64 Disk Image</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.diskinspector.d64</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>C128 Disk Image (D71)</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.diskinspector.d71</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>1581 Disk Image (D81)</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.diskinspector.d81</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>C64 Tape Archive (T64)</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.diskinspector.t64</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>C64 Lynx Archive (LNX)</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.diskinspector.lnx</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>C64 Raw GCR Disk Image (G64)</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.diskinspector.g64</string>
			</array>
		</dict>
		<dict>
			<key>CFBundleTypeName</key>
			<string>C64 Raw GCR Disk Image (NIB)</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<!-- Alternate rank to avoid conflict with macOS Interface Builder .nib files -->
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.diskinspector.c64nib</string>
			</array>
		</dict>
	</array>
</dict>
</plist>

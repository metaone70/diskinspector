<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- App identity -->
	<key>CFBundleDisplayName</key>
	<string>Disk Inspector</string>
	<key>CFBundleName</key>
	<string>Disk Inspector</string>
	<key>CFBundleShortVersionString</key>
	<string>1.4</string>
	<key>CFBundleVersion</key>
	<string>1.4</string>
	<key>NSHumanReadableCopyright</key>
	<string>© 2026 by metesev</string>
	<!-- Bundle the C64 Pro Mono font inside the app — no system install needed -->
	<key>ATSApplicationFontsPath</key>
	<string>.</string>
	<!-- Exported Type Declarations — these tell macOS about our custom file formats -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<!-- D64 Disk Image -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.d64</string>
			<key>UTTypeDescription</key>
			<string>C64 Disk Image (D64)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>d64</string>
				</array>
			</dict>
		</dict>
		<!-- D71 Disk Image -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.d71</string>
			<key>UTTypeDescription</key>
			<string>C128 Disk Image (D71)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>d71</string>
				</array>
			</dict>
		</dict>
		<!-- D81 Disk Image -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.d81</string>
			<key>UTTypeDescription</key>
			<string>1581 Disk Image (D81)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>d81</string>
				</array>
			</dict>
		</dict>
		<!-- D64File clipboard type (for drag-and-drop between windows) -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.d64file</string>
			<key>UTTypeDescription</key>
			<string>Disk Inspector File Entry</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict/>
		</dict>
		<!-- T64 Tape Archive -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.t64</string>
			<key>UTTypeDescription</key>
			<string>C64 Tape Archive (T64)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>t64</string>
				</array>
			</dict>
		</dict>
		<!-- LNX Lynx Archive -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.lnx</string>
			<key>UTTypeDescription</key>
			<string>C64 Lynx Archive (LNX)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>lnx</string>
				</array>
			</dict>
		</dict>
		<!-- G64 Raw GCR Disk Image -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.g64</string>
			<key>UTTypeDescription</key>
			<string>C64 Raw GCR Disk Image (G64)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>g64</string>
				</array>
			</dict>
		</dict>
		<!-- NIB Raw GCR Disk Image — uses com.diskinspector.c64nib to avoid conflict with macOS NIB files -->
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.diskinspector.c64nib</string>
			<key>UTTypeDescription</key>
			<string>C64 Raw GCR Disk Image (NIB)</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.data</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>nib</string>
				</array>
			</dict>
		</dict>
	</array>
